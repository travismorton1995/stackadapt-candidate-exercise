# Copy this file to .env and fill in real values. Never commit .env.

# Anthropic API key used by n8n's Anthropic Chat Model node.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# n8n encrypts stored credentials with this key. Generate any random string,
# e.g.: openssl rand -hex 32
# Keep it stable once set -- changing it invalidates saved n8n credentials.
N8N_ENCRYPTION_KEY=

# Fraction of /netsuite/invoices calls that return HTTP 500 (0.0-1.0).
# Set to 0 to disable flakiness (e.g. for automated tests).
FLAKY_RATE=0.2

# Timezone for n8n's Schedule Trigger nodes.
GENERIC_TIMEZONE=America/New_York
